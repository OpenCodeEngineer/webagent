# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/database
OPENCLAW_GATEWAY_TOKEN=replace-with-gateway-token
AUTH_SECRET=replace-with-random-secret

# ── Admin UI (Next.js) ────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.com
# Comma-separated list of admin emails for internal CRM access
ADMIN_EMAILS=admin@example.com

# ── Proxy ─────────────────────────────────────────────────────────────────────
PORT=3001
PROXY_CUSTOMER_API_TOKEN=replace-with-api-token
# OpenClaw gateway WebSocket URL (default: ws://127.0.0.1:18789)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# Directory where agent workspaces are stored
# OPENCLAW_WORKSPACES_DIR=/home/openclaw/openclaw/workspaces

# ── OAuth (optional — omit to disable) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email auth / magic link (optional — omit to disable) ──────────────────────
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=Lamoom <noreply@lamoom.com>

# ── Azure OpenAI (for OpenClaw agents) ────────────────────────────────────────
AZURE_DEV_AI_BASE_URL=https://your-resource.openai.azure.com
AZURE_DEV_AI_API_KEY=replace-with-azure-key
