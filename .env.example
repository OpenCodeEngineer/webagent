# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/database
OPENCLAW_GATEWAY_TOKEN=replace-with-gateway-token
AUTH_SECRET=replace-with-random-secret

# ── Admin UI (Next.js) ────────────────────────────────────────────────────────
# Canonical public URL of the admin app; used by NextAuth as the base for
# OAuth callbacks and by the proxy to generate widget embed codes.
# AUTH_URL is the NextAuth v5 name; NEXTAUTH_URL is the legacy alias — both
# are accepted (AUTH_SECRET / NEXTAUTH_SECRET work the same way).
NEXTAUTH_URL=https://your-domain.com
AUTH_URL=https://your-domain.com
# Client-side base URL for the admin app (used to build widget preview URLs in
# the browser; falls back to AUTH_URL when unset).
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Comma-separated list of admin emails for internal CRM access
ADMIN_EMAILS=admin@example.com
# Comma-separated invite allowlist for first-time account creation (empty = no open signup)
AUTH_INVITE_EMAILS=

# ── Proxy ─────────────────────────────────────────────────────────────────────
PORT=3001
# Bind proxy to localhost by default; public access should flow through nginx.
PROXY_BIND_HOST=127.0.0.1
# Listen port used by the proxy server (matches PORT above; read separately in
# the admin package to construct the server-side base URL when PROXY_URL is unset).
PROXY_PORT=3001
# Base URL the admin server uses to forward /api/agents/* rewrites to the proxy.
# When unset, Next.js rewrites fall back to http://127.0.0.1:<PROXY_PORT>.
PROXY_URL=http://127.0.0.1:3001
# Client-side base URL for the proxy, exposed to the browser via Next.js.
# Required when the proxy is not co-located with the admin app (e.g. CDN split).
# When unset, admin/src/lib/api.ts falls back to the server-side localhost URL.
NEXT_PUBLIC_PROXY_URL=
# Shared HMAC secret used by the admin server to sign X-Customer-Id/X-Customer-Sig
# headers on internal admin→proxy calls. Falls back to PROXY_API_TOKEN when unset.
PROXY_INTERNAL_SECRET=replace-with-internal-secret
# Primary bearer token expected by proxy routes, including POST /v1/chat/completions
PROXY_API_TOKEN=replace-with-api-token
# Optional fallback token for legacy/internal callers when PROXY_API_TOKEN is unset
PROXY_CUSTOMER_API_TOKEN=replace-with-customer-api-token
# OpenClaw gateway WebSocket URL (default: ws://127.0.0.1:18789)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# Token used to authenticate outbound webhook/hooks calls from the OpenClaw client.
# Defaults to OPENCLAW_GATEWAY_TOKEN when unset.
OPENCLAW_HOOKS_TOKEN=
# HTTP port the OpenClaw gateway listens on; used when building the Paperclip
# adapter gateway URL (default: 18789).
OPENCLAW_PORT=18789
# Path to the openclaw.json5 config file. Lookup order when unset:
#   1. <cwd>/openclaw/config/openclaw.json5
#   2. <repo-root>/openclaw/config/openclaw.json5
#   3. ~/.openclaw/openclaw.json
# OPENCLAW_CONFIG_PATH=/opt/webagent/openclaw/config/openclaw.json5
# Directory where the OpenClaw client persists device identity and session state.
# Defaults to $HOME/.openclaw, then <cwd>/.openclaw.
# OPENCLAW_STATE_DIR=/opt/webagent/.openclaw
# Directory where per-agent workspaces are stored. Lookup order when unset:
#   1. <cwd>/openclaw/workspaces
#   2. <repo-root>/openclaw/workspaces
#   3. ~/.openclaw/workspaces
# OPENCLAW_WORKSPACES_DIR=/opt/webagent/openclaw/workspaces
# Set to "true" to delete openclaw.json5 entries whose workspace dir no longer
# exists during reconciliation (default: false — orphaned entries are kept).
OPENCLAW_RECONCILE_REMOVE_ORPHANS=false

# ── OAuth (optional — omit to disable) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email auth / magic link (optional — omit to disable) ──────────────────────
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=Lamoom <noreply@lamoom.com>

# ── Azure OpenAI (for OpenClaw agents) ────────────────────────────────────────
AZURE_DEV_AI_BASE_URL=https://your-resource.openai.azure.com
AZURE_DEV_AI_API_KEY=replace-with-azure-key

# ── Paperclip (optional orchestration layer) ──────────────────────────────────
# Set to true to enable Paperclip control plane alongside OpenClaw
PAPERCLIP_ENABLED=false
PAPERCLIP_PORT=3100
PAPERCLIP_URL=http://localhost:3100
