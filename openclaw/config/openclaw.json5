{
  // Multi-agent configuration for Web MCP Agent platform
  gateway: {
    mode: "local",
    auth: {
      mode: "token",
      // Auto-generated on first run; do NOT set same as hooks.token
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    remote: {
      // Must match gateway.auth.token for CLI to connect
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: "azure-openai/gpt-5.1",
      // Workspace-scoped sandboxing: no Docker, file tools restricted to workspace only
      sandbox: { mode: "off" },
      heartbeat: {
        every: "30m",
        target: "none",
        lightContext: true,
        isolatedSession: true
      }
    },
    list: [
      {
        id: "meta",
        name: "Agent Builder",
        workspace: "~/openclaw",
        sandbox: { mode: "off" },
        skills: ["create-agent", "manage-agents"],
        heartbeat: { every: "0m" }
      }
    ]
  },
  hooks: {
    enabled: true,
    token: "${OPENCLAW_HOOKS_TOKEN}",
    path: "/hooks",
    allowRequestSessionKey: true,
    allowedSessionKeyPrefixes: ["agent:", "widget-", "admin-", "hook:"],
    defaultSessionKey: "hook:ingress",
    mappings: [
      {
        match: { path: "widget" },
        action: "agent",
        wakeMode: "now",
        deliver: false,  // proxy handles delivery via WebSocket
      },
    ],
  },
  cron: {
    enabled: true,
    maxConcurrentRuns: 3
  },
  session: {
    dmScope: "per-account-channel-peer",
    reset: { idleMinutes: 60 },
    maintenance: {
      mode: "enforce",
      pruneAfter: "7d",
      maxEntries: 1000
    }
  },
  models: {
    mode: "merge",
    providers: {
      "azure-openai": {
        baseUrl: "${AZURE_DEV_AI_BASE_URL}",
        apiKey: "${AZURE_DEV_AI_API_KEY}",
        api: "openai-completions",
        models: [
          { id: "gpt-5.1", name: "GPT-5.1 (Azure)" },
        ],
      },
    },
  },
}
