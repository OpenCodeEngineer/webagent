# LibreChat environment — copy to .env and fill in values
# Generate secrets: openssl rand -hex 32

HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=https://dev.lamoom.com
DOMAIN_SERVER=https://dev.lamoom.com

MONGO_URI=mongodb://mongodb:27017/LibreChat

# Auth secrets — MUST regenerate
CREDS_KEY=REPLACE_ME
CREDS_IV=REPLACE_ME_16_HEX
JWT_SECRET=REPLACE_ME
JWT_REFRESH_SECRET=REPLACE_ME

SESSION_EXPIRY=900000
REFRESH_TOKEN_EXPIRY=604800000

ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# Must match LIBRECHAT_API_KEY in /opt/webagent/.env
LIBRECHAT_API_KEY=REPLACE_ME

# Disable default providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_KEY=

DEBUG_LOGGING=true
