[Unit]
Description=WebAgent Proxy (port 3001)
After=network.target openclaw-gateway.service
Wants=network-online.target

[Service]
Type=simple
User=${APP_USER}
WorkingDirectory=${APP_DIR}
EnvironmentFile=-${APP_DIR}/.env
ExecStart=/usr/bin/pnpm --filter @webagent/proxy start
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=webagent-proxy

LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
