[Unit]
Description=WebAgent Admin UI (port 3000)
After=network.target webagent-proxy.service
Wants=network-online.target

[Service]
Type=simple
User=${APP_USER}
WorkingDirectory=${APP_DIR}
EnvironmentFile=-${APP_DIR}/.env
ExecStart=/usr/bin/pnpm --filter @webagent/admin start
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=webagent-admin

LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
